# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================================
# Dependencies & Package Managers
# ==========================================
node_modules/
/.pnp
.pnp.js

# ==========================================
# Build & Distribution Outputs
# ==========================================
dist/
dist-ssr/
build/
target/
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# ==========================================
# Environment Variables & Secrets
# ==========================================
*.local
.env
.env.keys
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ==========================================
# Logs & Crash Dumps
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
crash.log
crash.*.log

# ==========================================
# Testing & Code Coverage
# ==========================================
/coverage

# ==========================================
# Editors & IDEs
# ==========================================

# macOS OS-specific files
.DS_Store

# VS Code
.vscode/*
!.vscode/extensions.json

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Visual Studio / MSBuild
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# Spring Tool Suite (STS)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
.mvn/wrapper/maven-wrapper.jar

# ==========================================
# Terraform
# ==========================================
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and secrets. These should not be part of version
# control as they are data points which are passed in at runtime or variables.
*.tfvars
*.tfvars.json

# Ignore override files as they are local-only overrides to resources due to local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files to ignore the plan output of terraform
*.tfplan

# Ignore CLI config files
.terraformrc
terraform.rc
.terraform.lock.hcl

# ==========================================
# Supabase
# ==========================================
.branches/
.temp/

# ==========================================
# Miscellaneous & Tooling
# ==========================================
HELP.md
graphify-out/